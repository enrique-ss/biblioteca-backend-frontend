# Banco de Dados (Supabase PostgreSQL)
DB_HOST=seu-host.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha-supabase
DB_NAME=postgres
# Alternativamente, use a connection string do Supabase:
# DATABASE_URL=postgresql://postgres:[senha]@[host]:5432/postgres

# JWT
JWT_SECRET=sua-chave-secreta-super-segura-mude-isso-em-producao

# Servidor
PORT=3000
NODE_ENV=production

# CORS
CORS_ORIGIN=https://biblioteca-backend-frontend.onrender.com