{
  "name": "sistema-biblioteca",
  "version": "1.0.0",
  "scripts": {
    "setup": "ts-node src/setup.ts",
    "dev": "npx kill-port 3000 && nodemon src/index.ts",
    "cli": "ts-node src/cli.ts",
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "web": "npx kill-port 8080 && npx live-server public --port=8080 --host=0.0.0.0 --open=/index.html",
    "full": "npm run setup && concurrently \"npm run dev\" \"npm run web\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
