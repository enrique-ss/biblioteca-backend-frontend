{
  "name": "sistema-biblioteca",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "setup": "node src/setup.js",
    "dev": "npx kill-port 3000 && nodemon src/index.js",
    "cli": "node src/cli.js",
    "start": "node src/index.js",
    "web": "npx kill-port 8080 && npx live-server public --port=8080 --host=0.0.0.0 --open=/index.html",
    "full": "npm run setup && concurrently \"npm run dev\" \"npm run web\""
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.2"
  }
}
